# Development mode
NODE_ENV=development

# Supabase data/API
SUPABASE_URL=https://swnspkwknpjomkizfndd.supabase.co
SUPABASE_ANON_KEY=your_supabase_publishable_or_anon_key
# Server-only. Required after RLS is tightened because database routes must bypass
# public anon access through the Next.js backend only. Never expose this with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional separate admin email/password login
# Keep real values only in .env locally and Vercel Environment Variables.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password

# Firebase Google auth
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_web_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_web_app_id

# Enable the browser-local demo API. Leave false for production deployments
# unless you intentionally want localStorage-backed demo data on Vercel.
NEXT_PUBLIC_ENABLE_MOCK_API=false
